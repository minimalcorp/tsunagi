{
  "name": "@minimalcorp/tsunagi",
  "version": "0.1.0",
  "description": "Multi-repo GitHub project management with Claude AI integration, designed for visualizing and controlling AI-driven development locally.",
  "keywords": [
    "tsunagi",
    "claude",
    "claude-code",
    "ai",
    "agent",
    "task-management",
    "worktree",
    "github",
    "developer-tools"
  ],
  "homepage": "https://github.com/minimalcorp/tsunagi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minimalcorp/tsunagi.git"
  },
  "bugs": {
    "url": "https://github.com/minimalcorp/tsunagi/issues"
  },
  "author": "minimalcorp",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "bin": {
    "tsunagi": "./dist/scripts/cli.js"
  },
  "files": [
    "dist/**/*",
    "prisma/schema.prisma",
    "prisma/migrations/**/*",
    ".next/standalone/**/*",
    ".next/static/**/*",
    "tsunagi-marketplace/**/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx scripts/auto-migrate.ts && tsx scripts/with-plugin.ts dev",
    "server:dev": "tsx watch server/index.ts",
    "build": "prisma generate && next build",
    "build:dist": "tsc -p tsconfig.dist.json && chmod +x dist/scripts/cli.js",
    "start": "tsx scripts/auto-migrate.ts && tsx scripts/with-plugin.ts start",
    "postinstall": "prisma generate && node scripts/fix-node-pty-permissions.cjs",
    "prepack": "npm run build:dist && npm run build",
    "prepublishOnly": "npm run lint && npm run type-check",
    "lint": "eslint",
    "type-check": "tsc --noEmit && tsc --noEmit -p server/tsconfig.json",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "db:migrate-from-json": "tsx scripts/migrate-to-sqlite.ts",
    "db:backup": "tsx scripts/db-backup.ts",
    "db:restore": "tsx scripts/db-restore.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fastify/cors": "^11.2.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@libsql/client": "0.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.2",
    "fastify-socket.io": "^5.1.0",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "prisma": "^7.3.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "simple-git": "^3.30.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.30",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/trusted-types": "^2.0.7",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "eslint-config-prettier": "^10.1.8",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
