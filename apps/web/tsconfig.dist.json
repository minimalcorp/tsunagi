{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "declaration": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",
    "rootDir": "./",
    "sourceMap": false,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "server/**/*.ts",
    "scripts/**/*.ts",
    "src/lib/data-path.ts",
    "src/lib/db.ts",
    "src/lib/types.ts",
    "src/lib/repositories/**/*.ts",
    "src/lib/services/**/*.ts",
    "src/lib/worktree-manager.ts",
    "generated/prisma/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", ".next"]
}
