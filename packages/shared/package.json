{
  "name": "@minimalcorp/tsunagi-shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types for tsunagi monorepo",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.9.3"
  }
}
