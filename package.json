{
  "name": "tsunagi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/auto-migrate.ts && next dev -p 2791",
    "server:dev": "tsx watch server/index.ts",
    "build": "prisma generate && next build",
    "start": "tsx scripts/auto-migrate.ts && next start",
    "postinstall": "prisma generate && chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit && tsc --noEmit -p server/tsconfig.json",
    "prepare": "husky",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "db:migrate-from-json": "tsx scripts/migrate-to-sqlite.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.50",
    "@ark-ui/react": "^5.30.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@libsql/client": "0.8.1",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xyflow/react": "^12.10.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.2",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "node-pty": "^1.1.0",
    "prisma": "^7.3.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.30.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.30",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/trusted-types": "^2.0.7",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
